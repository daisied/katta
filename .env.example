# Katta Environment Configuration
# Copy this file to .env and fill in your values.

# Required: Discord bot token
DISCORD_BOT_TOKEN=your_bot_token_here

# Required: Your numeric Discord user ID (admin user)
ALLOWED_USER_ID=123456789012345678

# Required: SearXNG URL used by web_search/deep_research
SEARXNG_URL=http://searxng:8080

# LLM provider: openrouter or minimax
LLM_API_PROVIDER=openrouter

# Provider keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
MINIMAX_API_KEY=

# Optional generic override (takes precedence over provider-specific keys)
LLM_API_KEY=

# Optional API base URL override
LLM_BASE_URL=

# LLM model examples:
# OpenRouter: x-ai/grok-4.1-fast, minimax/minimax-m2.5
# MiniMax direct: MiniMax-M2.5, MiniMax-M2.5-highspeed
LLM_MODEL=x-ai/grok-4.1-fast

# Optional OpenRouter provider routing preference
OPENROUTER_PROVIDER=

# Optional GitHub token (for higher API limits)
GITHUB_TOKEN=

# Runtime behavior
# trusted = broad shell capability (power-user mode)
# safe    = blocks dangerous shell patterns (recommended default)
KATTA_COMMAND_MODE=safe

# OpenRouter reasoning controls
REASONING_ENABLED=false

# MiniMax reasoning controls
MINIMAX_REASONING_SPLIT=true

# Conversation history length per channel (message count)
HISTORY_LENGTH=8

# Optional timezone for prompt context
TIMEZONE=UTC

# Optional logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
